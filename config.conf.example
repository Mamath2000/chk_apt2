# Example configuration for apt_mqtt (copy to config.conf and edit)
# Protect the real config: chmod 600 config.conf

# MQTT broker settings
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Daemon behavior
CHECK_INTERVAL=3600
APT_MQTT_LOG_LEVEL=INFO

# Notes:
# - apt_mqtt utilise apt-update/<hostname> et docker_mqtt utilise docker-update/<hostname>.
# - Les topics globaux sont codés en dur: apt-update/global/update et docker-update/global/update.
# - Les client_id sont construits automatiquement à partir du hostname et du script.
# - Le répertoire d'installation est injecté par le service systemd.
# - AUTOREMOVE is configured in the daemon script.
# - APT_MQTT_LOG_LEVEL supports DEBUG, INFO, WARN, ERROR.