# Example configuration for apt_mqtt (copy to config.conf and edit)
# Protect the real config: chmod 600 config.conf

# MQTT broker settings
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# MQTT topics / discovery
MQTT_BASE_TOPIC=apt-update
OBJECT_ID=apt_update
MQTT_CLIENT_ID=apt_mqtt_$(hostname -s)
MQTT_GLOBAL_UPDATE_TOPIC=apt-update/global/update

# Daemon behavior
CHECK_INTERVAL=3600
APT_MQTT_SERVICE_NAME=apt-mqtt.service
APT_MQTT_INSTALL_DIR=

# Notes:
# - The final runtime topic becomes <MQTT_BASE_TOPIC>/<sanitized-hostname>/...
# - AUTOREMOVE is configured in the daemon script.